	"hex code": {
		"prefix": "hex code",
		"description": "",
		"scope": "",
		"body": [
			"```python {linenos=table,hl_lines=[2,4],linenostart=1,filename=\"hello.py\",base_url=\"https://github.com/imfing/hextra/blob/main/\",filename=\"docs/hugo.work\"}",
			"def say_hello():",
			"    print(\"Hello!\")",
			"",
			"def main():",
			"    say_hello()",
			"```"
		]
	},
