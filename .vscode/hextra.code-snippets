	"hex tabs": {
		"prefix": "hex tabs",
		"description": "",
		"scope": "",
		"body": [
			"{{< tabs >}}",
			"",
			"  {{< tab name=\"JSON\" selected=true >}}**JSON**: JavaScript Object Notation (JSON) is a standard text-based format for representing structured data based on JavaScript object syntax.{{< /tab >}}",
			"  {{< tab name=\"YAML\" icon=\"photograph\" >}}**YAML**: YAML is a human-readable data serialization language.{{< /tab >}}",
			"  {{< tab name=\"TOML\" >}}**TOML**: TOML aims to be a minimal configuration file format that's easy to read due to obvious semantics.{{< /tab >}}",
			"",
			"{{< /tabs >}}"
		]
	},
