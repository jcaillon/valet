	"hex filetree ": {
		"prefix": "hex filetree",
		"description": "",
		"scope": "",
		"body": [
			"{{< filetree/container >}}",
			"  {{< filetree/folder name=\"content\" >}}",
			"    {{< filetree/file name=\"_index.md\" >}}",
			"    {{< filetree/folder name=\"docs\" state=\"closed\" >}}",
			"      {{< filetree/file name=\"_index.md\" >}}",
			"      {{< filetree/file name=\"introduction.md\" >}}",
			"      {{< filetree/file name=\"introduction.fr.md\" >}}",
			"    {{< /filetree/folder >}}",
			"  {{< /filetree/folder >}}",
			"  {{< filetree/file name=\"hugo.toml\" >}}",
			"{{< /filetree/container >}}"
		]
	},
